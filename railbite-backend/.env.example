# ═══════════════════════════════════════════════════════════
# Email Configuration
# ⚠️ Render free tier BLOCKS outbound SMTP (ports 465/587).
#    Use Brevo or Resend HTTP API instead (sends over HTTPS).
# ═══════════════════════════════════════════════════════════

# RECOMMENDED: Brevo (free 300 emails/day)
#   1. Sign up at https://www.brevo.com (free)
#   2. Go to Settings → SMTP & API → API Keys → Generate
#   3. Add your sender email in Settings → Senders & Domains
# BREVO_API_KEY=xkeysib-xxxxxxxxxx
# BREVO_SENDER_EMAIL=rashidmostafa001@gmail.com

# ALTERNATIVE: Resend (free 100 emails/day)
# RESEND_API_KEY=re_xxxxxxxxxx

# FALLBACK: Gmail SMTP (works locally, BLOCKED on Render)
# GMAIL_USER=your.email@gmail.com
# GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# FALLBACK: Custom SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password

# Sender override (optional)
# EMAIL_FROM="RailBite Bangladesh" <your@email.com>

# Providers are tried in order: Brevo → Resend → SMTP/Gmail
# In dev with nothing configured, Ethereal test accounts are used.

